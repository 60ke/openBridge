{
  "name": "@openbridge/daemon",
  "version": "0.1.0",
  "description": "Local browser bridge daemon for AI agents - MCP and HTTP API",
  "type": "module",
  "bin": {
    "openbridge": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/60ke/openBridge.git"
  },
  "license": "MIT",
  "keywords": [
    "browser-bridge",
    "mcp",
    "chrome-extension",
    "ai-agent",
    "webbridge"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli/index.js serve"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@openbridge/shared": "workspace:*",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/ws": "^8.5.0"
  }
}