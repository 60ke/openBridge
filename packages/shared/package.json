{
  "name": "@openbridge-org/shared",
  "version": "0.1.3",
  "description": "Shared types and utilities for OpenBridge monorepo",
  "type": "module",
  "author": "OpenBridge contributors",
  "homepage": "https://github.com/60ke/openBridge#readme",
  "bugs": {
    "url": "https://github.com/60ke/openBridge/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/60ke/openBridge.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "keywords": [
    "browser-bridge",
    "openbridge",
    "shared-types"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
